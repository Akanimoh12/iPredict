# iPredict Frontend Environment Variables (Stacks)
# Copy this file to .env.local and fill in the values

# Stacks API URL (Testnet)
NEXT_PUBLIC_STACKS_API_URL=https://api.testnet.hiro.so

# Deployer / contract address (STX address that deployed the contracts)
NEXT_PUBLIC_DEPLOYER_ADDRESS=ST1XHPEWSZYNN2QA9QG9JG9GHRVF6GZSFRWTFB5VV

# Admin address (for admin-only functions like resolve-market, withdraw-fees)
NEXT_PUBLIC_ADMIN_ADDRESS=ST1XHPEWSZYNN2QA9QG9JG9GHRVF6GZSFRWTFB5VV

# Network: testnet or mainnet
NEXT_PUBLIC_NETWORK=testnet

# App URL (used for OG meta tags and canonical links)
NEXT_PUBLIC_APP_URL=https://ipredict-stacks.vercel.app
